{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/agent-proofs/bin/codex_hook.py\" session-start",
            "timeout": 30,
            "statusMessage": "Loading proofd guidance..."
          }
        ],
        "matcher": "startup|resume"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/agent-proofs/bin/codex_hook.py\" user-prompt-submit",
            "timeout": 30,
            "statusMessage": "Loading proofd context..."
          }
        ]
      }
    ]
  }
}
